{
  "name": "frontend",
  "private": true,
  "version": "1.2.7.dev1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build-aio": "tsc -p tsconfig.build.json && vite build --emptyOutDir --outDir ../acere/dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true ./",
    "generate-client": "openapi-ts",
    "generate-frontend-paths": "vite-node scripts/generate_frontend_route_list.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/noto-sans": "^5.2.10",
    "@tanstack/react-query": "^5.96.1",
    "@tanstack/react-query-devtools": "^5.96.1",
    "@tanstack/react-router": "^1.168.10",
    "axios": "^1.14.0",
    "form-data": "4.0.5",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-copy-to-clipboard-ts": "^1.3.1",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "7.71.1",
    "react-icons": "^5.6.0",
    "shaka-player": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@hey-api/openapi-ts": "0.73.0",
    "@playwright/test": "1.57.0",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "dotenv": "^17.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-node": "^5.3.0"
  }
}
