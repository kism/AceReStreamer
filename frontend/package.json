{
  "name": "frontend",
  "private": true,
  "version": "1.2.9.dev1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.build.json && vite build",
    "build-aio": "tsc -p tsconfig.build.json && vite build --emptyOutDir --outDir ../acere/dist",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write --unsafe --no-errors-on-unmatched --files-ignore-unknown=true ./",
    "generate-client": "openapi-ts",
    "generate-frontend-paths": "bun scripts/generate_frontend_route_list.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.36.0",
    "@emotion/react": "^11.14.0",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/noto-sans": "^5.2.10",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "7.71.1",
    "react-icons": "^5.7.0",
    "shaka-player": "^5.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@hey-api/openapi-ts": "0.73.0",
    "@playwright/test": "1.57.0",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "dotenv": "^17.4.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.6"
  }
}
